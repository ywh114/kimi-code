webview-ui/vite.config.ts
webview-ui/components.json

# Scripts
scripts/**
test/**
runtime/**
artifacts/**

# Never package generated test/debug state
**/.kimi/**
**/.kimi-code/**
**/cache/**
**/caches/**
**/credentials/**
**/logs/**
**/profile/**
**/profiles/**
**/session/**
**/sessions/**
**/tokens/**
